# ─── Orchestra Environment Configuration ─────────────────────────────────────
# Copy this file to .env and fill in the values.

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://orchestra:orchestra_dev@localhost:5432/orchestra

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis connection URL for caching and job queues
REDIS_URL=redis://localhost:6379

# ─── Core API ─────────────────────────────────────────────────────────────────
# Port for the NestJS core API
PORT=3001

# Node environment: development | production | test
NODE_ENV=development

# JWT secret for authentication tokens (generate a strong random string)
JWT_SECRET=change-me-to-a-strong-random-secret

# ─── Web Frontend ─────────────────────────────────────────────────────────────
# Public URL to the Core API (used by browser)
NEXT_PUBLIC_API_URL=http://localhost:3001

# NextAuth configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-strong-random-secret

# ─── Agent Configuration ─────────────────────────────────────────────────────
# Anthropic API key for Claude Code agents
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Default agent type: claude-code
AGENT_TYPE=claude-code

# Maximum retry attempts for agent self-healing loop
AGENT_MAX_RETRIES=3

# ─── GitHub Integration ──────────────────────────────────────────────────────
# GitHub App or personal access token for repo operations
GITHUB_TOKEN=ghp_xxxxx

# GitHub App ID and private key (if using GitHub App)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=

# ─── Docker / Container Registry ─────────────────────────────────────────────
# Container registry for agent images
# CONTAINER_REGISTRY=ghcr.io/your-org/orchestra

# ─── Observability ───────────────────────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL=info
